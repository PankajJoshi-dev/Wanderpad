<% layout("/layouts/boilerplate.ejs") %>

<h2 class="mt-3">Create a new Listing:</h2>
<div class="row">
  <div class="col-lg-8 col-md-10 col-sm-12 offset-lg-2 offset-md-1">
    <form
      action="/listings"
      method="POST"
      novalidate
      class="needs-validation"
      enctype="multipart/form-data"
    >
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          type="text"
          name="title"
          placeholder="Enter title..."
          class="form-control"
          required
        />
        <div class="valid-feedback">Title looks good!</div>
        <div class="invalid-feedback">Please enter a valid Title</div>
        <br />
      </div>
      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea
          name="description"
          id="description"
          placeholder="Description..."
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please enter a short description</div>
        <br />
      </div>
      <div class="mb-3">
        <label for="listing-image" class="form-label">Image</label>
        <input type="file" name="listing-image" class="form-control" /><br />
        <br />
      </div>
      <div class="row">
      <div class="mb-3 col-4">
        <label for="price" class="form-label">Price</label>
        <input
          type="number"
          name="price"
          placeholder="Enter price"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Invalid price</div>
        <br />
      </div>
      <div class="mb-3 col-4">
        <label for="price" class="form-label">Category</label>
        <input
          name="text"
          placeholder="Enter category"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Invalid category</div>
        <br />
      </div>
      </div>
      <div class="row">
        <div class="mb-3 col-4">
          <label for="location" class="form-label">Location</label>
          <input
            type="text"
            name="location"
            placeholder="Enter location"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please enter a valid location</div>
          <br />
        </div>
        <div class="mb-3 col-4">
          <label for="country" class="form-label">Country</label>
          <input
            type="text"
            name="country"
            placeholder="Enter country"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please enter a valid country name</div>
          <br />
        </div>
      </div>
        <div style="text-align: center">
          <button class="btn btn-dark add-btn">Add</button>
        </div>
    </form>
  </div>
</div>
